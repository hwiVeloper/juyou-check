# 오피넷 Open API 키
# 발급: https://www.opinet.co.kr → 회원가입 → 오픈API 신청
OPINET_API_KEY=

# 카카오맵 JavaScript API 키
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → JavaScript 키
NEXT_PUBLIC_KAKAO_MAP_KEY=

# Google AdSense 클라이언트 ID (ca-pub-XXXXXXXXXX)
# 발급: https://www.google.com/adsense → 계정 정보
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Google AdSense 광고 슬롯 ID
# 발급: https://www.google.com/adsense → 광고 → 광고 단위 → 디스플레이 광고
NEXT_PUBLIC_ADSENSE_AD_SLOT=

# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
# 발급: https://analytics.google.com → 관리 → 데이터 스트림 → 측정 ID
NEXT_PUBLIC_GA_ID=
